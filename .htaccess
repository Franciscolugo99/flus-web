Options -Indexes
DirectoryIndex index.php index.html
ErrorDocument 404 /404.php

<FilesMatch "(^\.|\.env$|\.pem$|\.sql$|\.bak$|\.old$|\.zip$|\.rar$|\.7z$)">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Deny from all
  </IfModule>
</FilesMatch>

# ── Compresión GZIP ──────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml text/xml application/xml
  AddOutputFilterByType DEFLATE font/woff2 font/woff application/font-woff2
</IfModule>

# ── Caché de assets estáticos ────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On

  # Imágenes — 1 año (se versionan con ?v= en el CSS)
  ExpiresByType image/png  "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif  "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"

  # Fuentes — 1 año
  ExpiresByType font/woff2      "access plus 1 year"
  ExpiresByType font/woff       "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"

  # CSS y JS — 1 mes (versión por filemtime ya en el PHP)
  ExpiresByType text/css        "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"

  # HTML/PHP — sin caché (siempre fresco)
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
  # Activar caché para assets
  <FilesMatch "\.(css|js|png|jpg|jpeg|gif|webp|svg|ico|woff2|woff)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Sin caché para PHP
  <FilesMatch "\.php$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
  </FilesMatch>

  # ── Headers de seguridad ──────────────────────────────────
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https://challenges.cloudflare.com; frame-src https://challenges.cloudflare.com"
</IfModule>

# ── Forzar HTTPS (activar cuando tengas SSL en Wiroos) ───────
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTP_HOST} !^(localhost|127\.0\.0\.1)(:\d+)?$ [NC]
  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
  RewriteRule ^ https://flus.com.ar%{REQUEST_URI} [L,R=301]
</IfModule>

# ── Ocultar extensión .php en la URL ─────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}\.php -f
  RewriteRule ^([^/]+)$ $1.php [L]
</IfModule>
