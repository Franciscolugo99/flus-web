Options -Indexes
DirectoryIndex index.php index.html
ErrorDocument 404 /404.php

# ── Compresión GZIP ──────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml text/xml application/xml
  AddOutputFilterByType DEFLATE font/woff2 font/woff application/font-woff2
</IfModule>

# ── Caché de assets estáticos ────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On

  # Imágenes — 1 año (se versionan con ?v= en el CSS)
  ExpiresByType image/png  "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif  "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"

  # Fuentes — 1 año
  ExpiresByType font/woff2      "access plus 1 year"
  ExpiresByType font/woff       "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"

  # CSS y JS — 1 mes (versión por filemtime ya en el PHP)
  ExpiresByType text/css        "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"

  # HTML/PHP — sin caché (siempre fresco)
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
  # Activar caché para assets
  <FilesMatch "\.(css|js|png|jpg|jpeg|gif|webp|svg|ico|woff2|woff)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Sin caché para PHP
  <FilesMatch "\.php$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
  </FilesMatch>

  # ── Headers de seguridad ──────────────────────────────────
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# ── Forzar HTTPS (activar cuando tengas SSL en Wiroos) ───────
# <IfModule mod_rewrite.c>
#   RewriteEngine On
#   RewriteCond %{HTTPS} off
#   RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
# </IfModule>

# ── Ocultar extensión .php en la URL ─────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}\.php -f
  RewriteRule ^([^/]+)$ $1.php [L]
</IfModule>
